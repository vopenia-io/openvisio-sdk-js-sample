# Copy to .env and fill in the values.

# OpenVisio proxy and frontend URLs
PROXY_URL=https://openvisio-proxy.example.com
OPENVISIO_URL=https://openvisio.example.com

# Shared secret authenticating this portal with the OpenVisio proxy.
OPENVISIO_API_KEY=

PORT=4000

# Identity provider (Keycloak) — Authorization Code + PKCE login.
# The portal client MUST allow this redirect URI:
#   http://localhost:4000/api/portal/callback
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=meet
PORTAL_CLIENT_ID=openvisio-portal
# Only if the portal client is confidential (ask the OpenVisio admin):
PORTAL_CLIENT_SECRET=
# Public base URL of this sample (used to build the redirect/callback URIs):
PORTAL_BASE_URL=http://localhost:4000

# Override the CDN URL of the published @openvisio/sdk-js browser bundle.
# Default points at esm.sh (auto-mirror of npmjs.com).
# SDK_BROWSER_URL=https://esm.sh/@openvisio/sdk-js@2.0.1/browser
