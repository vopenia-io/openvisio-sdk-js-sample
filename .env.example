# Copy to .env and fill in the blanks.
# Values for the staging environment live in container-registry/api/.env.staging.
# Staging only — do NOT point this at prod.

# The api proxy this portal talks to, and the Meet app it renders.
PROXY_URL=https://api.staging.openvisio.fr
MEET_URL=https://app.staging.openvisio.fr

# Shared secret sent as X-Api-Key to the proxy (the proxy trusts the portal).
# API_KEY is the current name; MAGO_API_KEY is accepted as a legacy fallback.
API_KEY=

# Port this demo listens on.
PORT=4000

# ── Keycloak portal login (Authorization Code + PKCE, BFF pattern) ──────────────
# The `mago-portal` client MUST allow this redirect URI:
#   http://localhost:4000/api/portal/callback
KEYCLOAK_URL=https://keycloak.staging.openvisio.fr
KEYCLOAK_REALM=meet
PORTAL_CLIENT_ID=mago-portal
# Set only if mago-portal is a confidential client (ask the Meet admin).
PORTAL_CLIENT_SECRET=
# Public base URL of this demo — used to build the redirect/callback URIs.
PORTAL_BASE_URL=http://localhost:4000

# ── LiveKit TURN relay (private / vRack clusters only) ─────────────────────────
# On a private cluster LiveKit only exposes a pod-IP ICE candidate, reachable
# solely through the Stunner TURN relay. These creds are handed to the browser so
# it forces relay-only ICE; without them: "could not establish pc connection".
# Same values as the deployed Stunner GatewayConfig (vault stunner_password).
# Leave empty on a public cluster.
LIVEKIT_TURN_URL=turn:stunner.staging.openvisio.fr:3478?transport=udp
LIVEKIT_TURN_USERNAME=livekit-turn-user
LIVEKIT_TURN_CREDENTIAL=
